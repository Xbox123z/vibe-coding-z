        function createCube() {
            // Clear existing cubes
            cubes.forEach(cube => scene.remove(cube));
            cubes = [];

            const geometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
            
            // Create 27 cubies (3x3x3)
            for (let x = -1; x <= 1; x++) {
                for (let y = -1; y <= 1; y++) {
                    for (let z = -1; z <= 1; z++) {
                        const materials = createMaterials(x, y, z);
                        const cube = new THREE.Mesh(geometry, materials);
                        
                        cube.position.set(x, y, z);
                        cube.castShadow = true;
                        cube.receiveShadow = true;
                        
                        // Store original position for logic
                        cube.userData = { 
                            originalPos: {x, y, z},
                            currentPos: {x, y, z}
                        };
                        
                        scene.add(cube);
                        cubes.push(cube);
                    }
                }
            }
        }

        function createMaterials(x, y, z) {
            const materials = [];
            
            // Right face (x = 1)
            materials.push(new THREE.MeshStandardMaterial({ 
                color: x === 1 ? COLORS.R : COLORS.CORE,
                roughness: 0.2,
                metalness: 0.1
            }));
            
            // Left face (x = -1)
            materials.push(new THREE.MeshStandardMaterial({ 
                color: x === -1 ? COLORS.L : COLORS.CORE,
                roughness: 0.2,
                metalness: 0.1
            }));
            
            // Top face (y = 1)
            materials.push(new THREE.MeshStandardMaterial({ 
                color: y === 1 ? COLORS.U : COLORS.CORE,
                roughness: 0.2,
                metalness: 0.1
            }));
            
            // Bottom face (y = -1)
            materials.push(new THREE.MeshStandardMaterial({ 
                color: y === -1 ? COLORS.D : COLORS.CORE,
                roughness: 0.2,
                metalness: 0.1
            }));
            
            // Front face (z = 1)
            materials.push(new THREE.MeshStandardMaterial({ 
                color: z === 1 ? COLORS.F : COLORS.CORE,
                roughness: 0.2,
                metalness: 0.1
            }));
            
            // Back face (z = -1)
            materials.push(new THREE.MeshStandardMaterial({ 
                color: z === -1 ? COLORS.B : COLORS.CORE,
                roughness: 0.2,
                metalness: 0.1
            }));
            
            return materials;
        }

        // ==========================================
        // Cube Rotation Logic
        // ==========================================

        function getCubiesOnFace(face) {
            const axis = face === 'U' || face === 'D' ? 'y' :
                        face === 'F' || face === 'B' ? 'z' : 'x';
            const value = face === 'U' || face === 'F' || face === 'R' ? 1 : -1;
            
            return cubes.filter(cube => {
                const pos = cube.position;
                return Math.abs(pos[axis] - value) < 0.1;
            });
        }

        function rotateFace(face, clockwise = true, duration = 300) {
            return new Promise((resolve) => {
                const cubies = getCubiesOnFace(face);
                const axis = face === 'U' || face === 'D' ? 'y' :
                            face === 'F' || face === 'B' ? 'z' : 'x';
                
                const direction = (face === 'U' || face === 'F' || face === 'R') ? 1 : -1;
                const angle = (clockwise ? 1 : -1) * direction * Math.PI / 2;
                
                // Create a pivot group
                const pivot = new THREE.Group();
                scene.add(pivot);
                
                // Attach cubies to pivot
                cubies.forEach(cube => {
                    pivot.attach(cube);
                });
                
                // Animate rotation
                const startTime = Date.now();
                const startRotation = pivot.rotation[axis];
                
                function animateRotation() {
                    const elapsed = Date.now() - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    
                    // Easing function (ease-out-cubic)
                    const ease = 1 - Math.pow(1 - progress, 3);
                    
                    pivot.rotation[axis] = startRotation + angle * ease;
                    
                    if (progress < 1) {
                        requestAnimationFrame(animateRotation);
                    } else {
                        // Detach cubies and cleanup
                        pivot.updateMatrixWorld();
                        cubies.forEach(cube => {
                            scene.attach(cube);
                            // Snap to grid
                            cube.position.x = Math.round(cube.position.x);
                            cube.position.y = Math.round(cube.position.y);
                            cube.position.z = Math.round(cube.position.z);
                            
                            // Snap rotation
                            cube.rotation.x = Math.round(cube.rotation.x / (Math.PI/2)) * (Math.PI/2);
                            cube.rotation.y = Math.round(cube.rotation.y / (Math.PI/2)) * (Math.PI/2);
                            cube.rotation.z = Math.round(cube.rotation.z / (Math.PI/2)) * (Math.PI/2);
                        });
                        
                        scene.remove(pivot);
                        updateFaceColors(face, clockwise);
                        resolve();
                    }
                }
                
                animateRotation();
            });
        }

        function updateFaceColors(face, clockwise) {
            // Update the logical state of the cube
            const faces = ['U', 'R', 'F', 'D', 'L', 'B'];
            const faceIndex = faces.indexOf(face);
            
            // This is a simplified state update
