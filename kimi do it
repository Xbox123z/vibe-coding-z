        }

        // ==========================================
        // Move Notation
        // ==========================================

        const MOVE_MAP = {
            'U': () => rotateFace('U', true),
            "U'": () => rotateFace('U', false),
            'D': () => rotateFace('D', true),
            "D'": () => rotateFace('D', false),
            'F': () => rotateFace('F', true),
            "F'": () => rotateFace('F', false),
            'B': () => rotateFace('B', true),
            "B'": () => rotateFace('B', false),
            'L': () => rotateFace('L', true),
            "L'": () => rotateFace('L', false),
            'R': () => rotateFace('R', true),
            "R'": () => rotateFace('R', false),
            'U2': async () => { await rotateFace('U', true); await rotateFace('U', true); },
            'D2': async () => { await rotateFace('D', true); await rotateFace('D', true); },
            'F2': async () => { await rotateFace('F', true); await rotateFace('F', true); },
            'B2': async () => { await rotateFace('B', true); await rotateFace('B', true); },
            'L2': async () => { await rotateFace('L', true); await rotateFace('L', true); },
            'R2': async () => { await rotateFace('R', true); await rotateFace('R', true); },
        };

        async function executeMove(move) {
            const moveFunc = MOVE_MAP[move];
            if (moveFunc) {
                await moveFunc();
                logMove(move);
            }
        }

        async function executeMoves(moves) {
            setStatus('busy', '执行中...');
            for (const move of moves) {
                if (move.trim()) {
                    await executeMove(move.trim());
                    await new Promise(r => setTimeout(r, 50)); // Small delay between moves
                }
            }
            setStatus('idle', '就绪');
        }

        // ==========================================
        // Scrambling
        // ==========================================

        function generateScramble(length = 20) {
            const moves = ['U', 'D', 'F', 'B', 'L', 'R'];
            const modifiers = ['', "'", '2'];
            const scramble = [];
            
            for (let i = 0; i < length; i++) {
                const move = moves[Math.floor(Math.random() * moves.length)];
                const mod = modifiers[Math.floor(Math.random() * modifiers.length)];
                scramble.push(move + mod);
            }
            
            return scramble;
        }

        async function scramble() {
            if (isAnimating) return;
            isAnimating = true;
            
            clearLog();
            const scrambleMoves = generateScramble();
