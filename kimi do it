            L: 0x00ff00, // Green
            R: 0x0000ff, // Blue
            CORE: 0x111111 // Black core
        };

        // Initial solved state
        let faceColors = {
            U: Array(9).fill(COLORS.U),
            D: Array(9).fill(COLORS.D),
            F: Array(9).fill(COLORS.F),
            B: Array(9).fill(COLORS.B),
            L: Array(9).fill(COLORS.L),
            R: Array(9).fill(COLORS.R)
        };

        // Position to face mapping
        const POS_TO_FACE = {
            '0,1,0': 'U', '0,-1,0': 'D', '0,0,1': 'F',
            '0,0,-1': 'B', '-1,0,0': 'L', '1,0,0': 'R'
